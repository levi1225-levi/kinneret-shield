# Environment Configuration
NODE_ENV=development
PORT=3000

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@localhost:5432/kinneret_shield

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=86400

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# CORS Configuration
CORS_ORIGIN=http://localhost:3001

# Device Configuration
DEVICE_AUTH_SECRET=your-device-auth-secret-for-nfc-readers
DEVICE_HEARTBEAT_INTERVAL=30000
DEVICE_HEARTBEAT_TIMEOUT=120000

# Attendance Configuration
AUTO_CHECKOUT_TIMEOUT=3600000
ATTENDANCE_ALERT_THRESHOLD=2

# Alert Configuration
ALERT_UNKNOWN_CARD_ENABLED=true
ALERT_DEVICE_OFFLINE_ENABLED=true
ALERT_CAPACITY_EXCEEDED_ENABLED=true

# Daily Report Configuration
DAILY_REPORT_CRON=0 0 * * *

# Logging
LOG_LEVEL=debug

# Webhook Configuration (for future integrations)
WEBHOOK_SECRET=your-webhook-secret
